# Firebase — Client SDK (safe to expose, used in browser)
# Find these in: Firebase Console → Project Settings → Your apps → Web app config
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:xxxxxxxxxxxxxxxx

# Firebase — Admin SDK (keep secret, server-only)
# Find this in: Firebase Console → Project Settings → Service Accounts → Generate new private key
# Minify the downloaded JSON to a single line before pasting here
FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"..."}

# Gemini API
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key
# Set to "true" to use keyword-based mock extraction (no API calls, great for development)
GEMINI_MOCK=true

# Twilio WhatsApp
# Find Account SID and Auth Token in: Twilio Console → Account Info
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
# For Twilio Sandbox this is always the same number
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Application config
# Phone number that receives escalation alerts — include country code (e.g. +919XXXXXXXXX)
COORDINATOR_PHONE=+91XXXXXXXXXX
# true = 1-minute escalation threshold + 30s polling (for demos and testing)
# false = 10-minute threshold (for production)
NEXT_PUBLIC_TEST_MODE=true
# Secret token required in the x-admin-secret header for the /api/fix-phones endpoint
ADMIN_SECRET=choose_a_strong_secret_here
